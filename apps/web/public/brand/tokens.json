{
  "$description": "AgentsOX brand tokens in a DTCG-inspired structure for design and frontend implementation.",
  "color": {
    "$type": "color",
    "primitive": {
      "black": {
        "$value": "#0A0A0F",
        "$description": "Primary dark background."
      },
      "surface": {
        "$value": "#12121A",
        "$description": "Default panel, card, and nav surface."
      },
      "surfaceRaised": {
        "$value": "#1A1A25",
        "$description": "Raised or emphasized dark surface."
      },
      "text": {
        "$value": "#EEEEF0",
        "$description": "Primary text on dark backgrounds."
      },
      "textMuted": {
        "$value": "#A0A0B0",
        "$description": "Secondary text on dark backgrounds."
      },
      "cyan": {
        "$value": "#22D3EE",
        "$description": "Primary brand energy and focus accent."
      },
      "blue": {
        "$value": "#3B82F6",
        "$description": "Primary action and gradient end."
      },
      "emerald": {
        "$value": "#10B981",
        "$description": "Success and positive system state."
      },
      "red": {
        "$value": "#E53E3E",
        "$description": "Error and destructive state."
      },
      "amber": {
        "$value": "#F59E0B",
        "$description": "Warning and review state."
      },
      "border": {
        "$value": "#2A2A3A",
        "$description": "Default dark-mode border."
      }
    },
    "semantic": {
      "background": {
        "$value": "{color.primitive.black}",
        "$description": "Page background."
      },
      "surface": {
        "$value": "{color.primitive.surface}",
        "$description": "Cards, panels, and navigation."
      },
      "surfaceRaised": {
        "$value": "{color.primitive.surfaceRaised}",
        "$description": "Raised panels and emphasized containers."
      },
      "textPrimary": {
        "$value": "{color.primitive.text}",
        "$description": "Primary readable text."
      },
      "textSecondary": {
        "$value": "{color.primitive.textMuted}",
        "$description": "Secondary copy and helper text."
      },
      "actionPrimary": {
        "$value": "{color.primitive.blue}",
        "$description": "Primary CTA fill and active state."
      },
      "focus": {
        "$value": "{color.primitive.cyan}",
        "$description": "Focus ring and accessibility outline."
      },
      "statusSuccess": {
        "$value": "{color.primitive.emerald}",
        "$description": "Completed, healthy, or positive states."
      },
      "statusWarning": {
        "$value": "{color.primitive.amber}",
        "$description": "Needs review or attention."
      },
      "statusError": {
        "$value": "{color.primitive.red}",
        "$description": "Failed, destructive, or blocked states."
      },
      "borderDefault": {
        "$value": "{color.primitive.border}",
        "$description": "Default border and divider."
      }
    }
  },
  "typography": {
    "fontFamily": {
      "$type": "fontFamily",
      "heading": {
        "$value": ["Plus Jakarta Sans", "system-ui", "sans-serif"]
      },
      "body": {
        "$value": ["Figtree", "system-ui", "sans-serif"]
      },
      "mono": {
        "$value": ["JetBrains Mono", "ui-monospace", "monospace"]
      }
    },
    "fontWeight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 },
      "extraBold": { "$value": 800 }
    },
    "scale": {
      "hero": {
        "$type": "dimension",
        "$value": "64px",
        "$description": "Desktop hero heading size."
      },
      "h1": {
        "$type": "dimension",
        "$value": "48px"
      },
      "h2": {
        "$type": "dimension",
        "$value": "36px"
      },
      "h3": {
        "$type": "dimension",
        "$value": "24px"
      },
      "body": {
        "$type": "dimension",
        "$value": "16px"
      },
      "small": {
        "$type": "dimension",
        "$value": "14px"
      },
      "code": {
        "$type": "dimension",
        "$value": "14px"
      }
    }
  },
  "space": {
    "$type": "dimension",
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "6": { "$value": "24px" },
    "8": { "$value": "32px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" },
    "24": { "$value": "96px" }
  },
  "radius": {
    "$type": "dimension",
    "control": {
      "$value": "10px",
      "$description": "Default button/control radius."
    },
    "card": {
      "$value": "8px",
      "$description": "Default card and panel radius."
    },
    "container": {
      "$value": "12px",
      "$description": "Large panel, modal, and page-section container radius."
    },
    "pill": {
      "$value": "999px",
      "$description": "Tags and true pill controls only."
    }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "150ms" },
      "base": { "$value": "250ms" },
      "slow": { "$value": "400ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": {
        "$value": [0.16, 1, 0.3, 1],
        "$description": "Precise ease-out for premium but quiet interactions."
      }
    }
  }
}
