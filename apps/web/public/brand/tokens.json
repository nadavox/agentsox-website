{
  "$description": "AgentsOX brand tokens in a DTCG-inspired structure. THE single source of truth for every brand value. Run `npm run build:tokens` to regenerate dist/brand.css. Never hardcode a brand value anywhere else.",
  "color": {
    "$type": "color",
    "primitive": {
      "black": {
        "$value": "#101018",
        "$description": "Primary dark background. Lifted off near-black (was #0A0A0F) for elevation headroom and less halation/OLED smear, per Material 3 / Apple HIG / NN-g. Keeps the cool blue tint."
      },
      "surface": {
        "$value": "#16161F",
        "$description": "Default panel, card, and nav surface (one even step up from the base)."
      },
      "surfaceRaised": {
        "$value": "#1E1E29",
        "$description": "Raised or emphasized dark surface (elevation = lighter, no shadow needed)."
      },
      "text": {
        "$value": "#EEEEF0",
        "$description": "Primary text on dark backgrounds. 17.6:1 on black (AAA)."
      },
      "textMuted": {
        "$value": "#A0A0B0",
        "$description": "Secondary text on dark backgrounds. 7.0:1 on black (AAA)."
      },
      "textDim": {
        "$value": "#8A8AA2",
        "$description": "Tertiary text on dark. Lifted to meet AA (>=4.5:1) on the base and all dark surfaces (was #6B6B80, large-text-only)."
      },
      "cyan": {
        "$value": "#22D3EE",
        "$description": "Primary brand energy and focus accent."
      },
      "cyanHover": {
        "$value": "#67E8F9",
        "$description": "Lighter cyan for hover/active on dark surfaces."
      },
      "blue": {
        "$value": "#3B82F6",
        "$description": "Primary action and gradient end."
      },
      "blueHover": {
        "$value": "#60A5FA",
        "$description": "Lighter blue for hover on dark surfaces."
      },
      "blueActive": {
        "$value": "#2563EB",
        "$description": "Darker blue. AA-safe fill for white button labels (5.2:1) and pressed state."
      },
      "emerald": {
        "$value": "#10B981",
        "$description": "Success and positive system state."
      },
      "red": {
        "$value": "#E53E3E",
        "$description": "Error and destructive state."
      },
      "amber": {
        "$value": "#F59E0B",
        "$description": "Warning and review state."
      },
      "border": {
        "$value": "#2A2A3A",
        "$description": "Default dark-mode divider (decorative, subtle)."
      },
      "borderStrong": {
        "$value": "#62627A",
        "$description": "Functional border for inputs and selected states on dark (meets the 3:1 non-text bar on the lifted base)."
      },
      "sunken": {
        "$value": "#08080D",
        "$description": "Recessed/sunken surface, darker than the page background (wells, insets)."
      }
    },
    "primitiveLight": {
      "$description": "Light-theme raw values. Light elevation lifts UP toward white with shadow (cards are lighter than the page), per Material 3 / Apple HIG / Atlassian. Accents are darkened so they stay legible on light surfaces.",
      "paper": { "$value": "#F4F4FA", "$description": "Light page background. Slightly off-white so white cards lift above it." },
      "card": { "$value": "#FFFFFF", "$description": "Light surface, card, and overlay. Depth comes from shadow, not a darker fill." },
      "well": { "$value": "#ECECF3", "$description": "Sunken/recessed surface on light (wells, code blocks, insets)." },
      "ink": { "$value": "#0A0A0F", "$description": "Primary text on light. ~19:1 (AAA)." },
      "inkMuted": { "$value": "#3A3A4A", "$description": "Secondary text on light. ~10:1 (AAA)." },
      "inkDim": { "$value": "#5E5E70", "$description": "Tertiary text on light. AA (>=4.5:1) on paper and white cards." },
      "cyanInk": { "$value": "#0E7490", "$description": "Cyan darkened for light surfaces. AA as text/icon on light (was #0891B2, which failed)." },
      "blueInk": { "$value": "#2563EB", "$description": "Blue action fill on light (white label AA)." },
      "blueInkStrong": { "$value": "#1D4ED8", "$description": "Blue text and pressed state on light (~6.4:1)." },
      "emeraldInk": { "$value": "#047857", "$description": "Success on light (AA as text)." },
      "amberInk": { "$value": "#B45309", "$description": "Warning on light (AA as text)." },
      "redInk": { "$value": "#DC2626", "$description": "Error on light (AA as text)." },
      "borderLight": { "$value": "#D8D8E4", "$description": "Subtle divider on light (decorative)." },
      "borderStrongLight": { "$value": "#8A8A9C", "$description": "Functional border for inputs and selected states on light (~3.2:1)." }
    },
    "semantic": {
      "background": {
        "$value": "{color.primitive.black}",
        "$description": "Page background."
      },
      "surface": {
        "$value": "{color.primitive.surface}",
        "$description": "Cards, panels, and navigation."
      },
      "surfaceRaised": {
        "$value": "{color.primitive.surfaceRaised}",
        "$description": "Raised panels and emphasized containers."
      },
      "textPrimary": {
        "$value": "{color.primitive.text}",
        "$description": "Primary readable text."
      },
      "textSecondary": {
        "$value": "{color.primitive.textMuted}",
        "$description": "Secondary copy and helper text."
      },
      "textTertiary": {
        "$value": "{color.primitive.textDim}",
        "$description": "Tertiary, faint, or disabled text."
      },
      "actionPrimary": {
        "$value": "{color.primitive.blue}",
        "$description": "Primary CTA fill and active accent. For white labels at body size, use actionStrong (AA)."
      },
      "actionStrong": {
        "$value": "{color.primitive.blueActive}",
        "$description": "AA-safe primary fill when white text sits on it at body size (5.1:1)."
      },
      "actionHover": {
        "$value": "{color.primitive.blueHover}",
        "$description": "Hover state for primary actions on dark."
      },
      "focus": {
        "$value": "{color.primitive.cyan}",
        "$description": "Focus ring and accessibility outline."
      },
      "statusSuccess": {
        "$value": "{color.primitive.emerald}",
        "$description": "Completed, healthy, or positive states."
      },
      "statusWarning": {
        "$value": "{color.primitive.amber}",
        "$description": "Needs review or attention."
      },
      "statusError": {
        "$value": "{color.primitive.red}",
        "$description": "Failed, destructive, or blocked states."
      },
      "borderDefault": {
        "$value": "{color.primitive.border}",
        "$description": "Default divider (decorative, subtle)."
      },
      "borderStrong": {
        "$value": "{color.primitive.borderStrong}",
        "$description": "Functional border for inputs, focus, and selected states (>=3:1)."
      },
      "surfaceSunken": {
        "$value": "{color.primitive.sunken}",
        "$description": "Recessed/sunken surface (wells, insets)."
      }
    },
    "semanticLight": {
      "$description": "Light-theme overrides. Same semantic names as the dark default; the generator emits these under [data-theme=\"light\"]. Opt in on <html> or any section with data-theme=\"light\".",
      "background": { "$value": "{color.primitiveLight.paper}" },
      "surface": { "$value": "{color.primitiveLight.card}" },
      "surfaceRaised": { "$value": "{color.primitiveLight.card}" },
      "surfaceSunken": { "$value": "{color.primitiveLight.well}" },
      "textPrimary": { "$value": "{color.primitiveLight.ink}" },
      "textSecondary": { "$value": "{color.primitiveLight.inkMuted}" },
      "textTertiary": { "$value": "{color.primitiveLight.inkDim}" },
      "actionPrimary": { "$value": "{color.primitiveLight.blueInk}" },
      "actionStrong": { "$value": "{color.primitiveLight.blueInkStrong}" },
      "actionHover": { "$value": "{color.primitiveLight.blueInkStrong}" },
      "focus": { "$value": "{color.primitiveLight.cyanInk}" },
      "statusSuccess": { "$value": "{color.primitiveLight.emeraldInk}" },
      "statusWarning": { "$value": "{color.primitiveLight.amberInk}" },
      "statusError": { "$value": "{color.primitiveLight.redInk}" },
      "borderDefault": { "$value": "{color.primitiveLight.borderLight}" },
      "borderStrong": { "$value": "{color.primitiveLight.borderStrongLight}" }
    }
  },
  "gradient": {
    "$type": "gradient",
    "$description": "CSS-ready gradient strings. Use for logo accents, focus rings, progress, hero details. Never as a large atmospheric page background.",
    "accent": {
      "$value": "linear-gradient(135deg, #22D3EE 0%, #3B82F6 70%, #10B981 100%)",
      "$description": "Signature three-stop accent."
    },
    "action": {
      "$value": "linear-gradient(135deg, #22D3EE, #3B82F6)",
      "$description": "Cyan to blue, for the OX wordmark accent and key gradient words."
    },
    "ambient": {
      "$value": "radial-gradient(circle at 22% 4%, rgba(34, 211, 238, 0.14), transparent 32%), radial-gradient(circle at 84% 12%, rgba(59, 130, 246, 0.10), transparent 34%), linear-gradient(180deg, #101018 0%, #16161F 48%, #101018 100%)",
      "$description": "Subtle page ambience for brand-book and hero surfaces only."
    }
  },
  "wash": {
    "$type": "color",
    "$description": "Translucent accent washes for tags, hovers, and focus halos.",
    "cyan": { "$value": "rgba(34, 211, 238, 0.12)" },
    "blue": { "$value": "rgba(59, 130, 246, 0.12)" },
    "emerald": { "$value": "rgba(16, 185, 129, 0.12)" },
    "red": { "$value": "rgba(229, 62, 62, 0.12)" },
    "amber": { "$value": "rgba(245, 158, 11, 0.12)" }
  },
  "typography": {
    "fontFamily": {
      "$type": "fontFamily",
      "heading": {
        "$value": ["Space Grotesk", "system-ui", "sans-serif"],
        "$description": "Headings, display, nav, buttons, section labels. Weights 700-800."
      },
      "body": {
        "$value": ["Inter", "system-ui", "sans-serif"],
        "$description": "Body, descriptions, forms, marketing. Weights 400-600."
      },
      "mono": {
        "$value": ["JetBrains Mono", "ui-monospace", "monospace"],
        "$description": "Code, tokens, logs, metadata, eyebrows/labels."
      }
    },
    "fontWeight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 },
      "extraBold": { "$value": 800 }
    },
    "scale": {
      "$description": "Desktop type sizes. Minor-third-inspired with pragmatic web steps.",
      "hero": {
        "$type": "dimension",
        "$value": "64px",
        "$description": "Desktop hero heading."
      },
      "h1": { "$type": "dimension", "$value": "48px" },
      "h2": { "$type": "dimension", "$value": "36px" },
      "h3": { "$type": "dimension", "$value": "24px" },
      "h4": { "$type": "dimension", "$value": "18px" },
      "bodyLg": { "$type": "dimension", "$value": "18px" },
      "body": { "$type": "dimension", "$value": "16px" },
      "small": { "$type": "dimension", "$value": "14px" },
      "label": {
        "$type": "dimension",
        "$value": "13px",
        "$description": "Uppercase mono UI label/eyebrow."
      },
      "code": { "$type": "dimension", "$value": "14px" }
    },
    "scaleMobile": {
      "$description": "Mobile overrides for large headings only.",
      "hero": { "$type": "dimension", "$value": "42px" },
      "h1": { "$type": "dimension", "$value": "36px" },
      "h2": { "$type": "dimension", "$value": "28px" },
      "h3": { "$type": "dimension", "$value": "21px" }
    },
    "lineHeight": {
      "$type": "number",
      "$description": "Unitless line-heights paired to each size role.",
      "hero": { "$value": 1.02 },
      "h1": { "$value": 1.08 },
      "h2": { "$value": 1.15 },
      "h3": { "$value": 1.2 },
      "h4": { "$value": 1.3 },
      "bodyLg": { "$value": 1.65 },
      "body": { "$value": 1.6 },
      "small": { "$value": 1.5 },
      "label": { "$value": 1.2 },
      "code": { "$value": 1.5 }
    },
    "letterSpacing": {
      "$type": "dimension",
      "label": {
        "$value": "0.08em",
        "$description": "Tracking for uppercase mono labels/eyebrows."
      }
    },
    "styles": {
      "$type": "typography",
      "$description": "Composite DTCG text styles for design tools (Tokens Studio / Figma). The CSS generator skips these; in code use the flat --font-*, --text-*, --line-height-* variables (and the .ox-* helper classes).",
      "hero": { "$value": { "fontFamily": "{typography.fontFamily.heading}", "fontSize": "{typography.scale.hero}", "fontWeight": "{typography.fontWeight.bold}", "lineHeight": "{typography.lineHeight.hero}", "letterSpacing": "-0.02em" } },
      "h1": { "$value": { "fontFamily": "{typography.fontFamily.heading}", "fontSize": "{typography.scale.h1}", "fontWeight": "{typography.fontWeight.bold}", "lineHeight": "{typography.lineHeight.h1}" } },
      "h2": { "$value": { "fontFamily": "{typography.fontFamily.heading}", "fontSize": "{typography.scale.h2}", "fontWeight": "{typography.fontWeight.bold}", "lineHeight": "{typography.lineHeight.h2}" } },
      "h3": { "$value": { "fontFamily": "{typography.fontFamily.heading}", "fontSize": "{typography.scale.h3}", "fontWeight": "{typography.fontWeight.bold}", "lineHeight": "{typography.lineHeight.h3}" } },
      "h4": { "$value": { "fontFamily": "{typography.fontFamily.heading}", "fontSize": "{typography.scale.h4}", "fontWeight": "{typography.fontWeight.semibold}", "lineHeight": "{typography.lineHeight.h4}" } },
      "bodyLg": { "$value": { "fontFamily": "{typography.fontFamily.body}", "fontSize": "{typography.scale.bodyLg}", "fontWeight": "{typography.fontWeight.regular}", "lineHeight": "{typography.lineHeight.bodyLg}" } },
      "body": { "$value": { "fontFamily": "{typography.fontFamily.body}", "fontSize": "{typography.scale.body}", "fontWeight": "{typography.fontWeight.regular}", "lineHeight": "{typography.lineHeight.body}" } },
      "small": { "$value": { "fontFamily": "{typography.fontFamily.body}", "fontSize": "{typography.scale.small}", "fontWeight": "{typography.fontWeight.regular}", "lineHeight": "{typography.lineHeight.small}" } },
      "label": { "$value": { "fontFamily": "{typography.fontFamily.mono}", "fontSize": "{typography.scale.label}", "fontWeight": "{typography.fontWeight.semibold}", "lineHeight": "{typography.lineHeight.label}", "letterSpacing": "{typography.letterSpacing.label}", "textCase": "uppercase" } },
      "code": { "$value": { "fontFamily": "{typography.fontFamily.mono}", "fontSize": "{typography.scale.code}", "fontWeight": "{typography.fontWeight.regular}", "lineHeight": "{typography.lineHeight.code}" } }
    }
  },
  "space": {
    "$type": "dimension",
    "$description": "4px base unit.",
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "6": { "$value": "24px" },
    "8": { "$value": "32px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" },
    "24": { "$value": "96px" }
  },
  "maxWidth": {
    "$description": "Layout max-widths.",
    "section": { "$type": "dimension", "$value": "1126px" },
    "copy": { "$value": "65ch", "$description": "Body copy measure." }
  },
  "radius": {
    "$type": "dimension",
    "control": {
      "$value": "10px",
      "$description": "Default button/control radius."
    },
    "card": {
      "$value": "8px",
      "$description": "Default card and panel radius."
    },
    "container": {
      "$value": "12px",
      "$description": "Large panel, modal, and page-section container radius."
    },
    "pill": {
      "$value": "999px",
      "$description": "Tags and true pill controls only."
    }
  },
  "shadow": {
    "$type": "shadow",
    "$description": "CSS-ready box-shadow strings. Soft, low-opacity elevation.",
    "card": { "$value": "0 28px 80px rgba(0, 0, 0, 0.42)" },
    "panel": { "$value": "0 24px 60px -30px rgba(0, 0, 0, 0.55)" },
    "soft": { "$value": "0 8px 24px rgba(0, 0, 0, 0.35)" },
    "focusRing": {
      "$value": "0 0 0 2px rgba(34, 211, 238, 0.6)",
      "$description": "2px cyan focus ring."
    }
  },
  "shadowLight": {
    "$type": "shadow",
    "$description": "Light-theme shadow overrides. Softer and cooler than the dark set; in light mode elevation is carried by shadow. Emitted under [data-theme=\"light\"].",
    "card": { "$value": "0 2px 6px rgba(16, 16, 40, 0.08), 0 8px 24px rgba(16, 16, 40, 0.10)" },
    "panel": { "$value": "0 12px 40px rgba(16, 16, 40, 0.16)" },
    "soft": { "$value": "0 1px 2px rgba(16, 16, 40, 0.06), 0 2px 8px rgba(16, 16, 40, 0.08)" },
    "focusRing": { "$value": "0 0 0 2px rgba(14, 116, 144, 0.7)" }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "150ms" },
      "base": { "$value": "250ms" },
      "slow": { "$value": "400ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": {
        "$value": [0.16, 1, 0.3, 1],
        "$description": "Precise ease-out for premium but quiet interactions."
      }
    }
  }
}
