{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon\\.svg|favicon-.*\\.png|apple-touch-icon\\.png|icon-.*\\.png|og-image\\.(svg|png)|robots\\.txt|sitemap\\.xml|manifest\\.json)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/google(.*)html", "destination": "/google$1html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
